# ===== Local development (docker-compose PostgreSQL) =====
POSTGRES_DB=figureshot
POSTGRES_USER=figureshot
POSTGRES_PASSWORD=change-me-local-only
POSTGRES_PORT=5432

# ===== Backend (Spring Boot) =====
# application-local.yml 讀取以下變數
DB_URL=jdbc:postgresql://localhost:5432/figureshot
DB_USERNAME=figureshot
DB_PASSWORD=change-me-local-only
JWT_SECRET=change-me-generate-a-long-random-string

# AI Provider(只存在後端環境,前端永不接觸)
ANTHROPIC_API_KEY=sk-ant-xxxx
AI_MODEL=claude-sonnet-4-5

# 圖片儲存(MVP 本機)
STORAGE_LOCAL_DIR=./uploads

# ===== Frontend (Nuxt) =====
NUXT_PUBLIC_API_BASE=http://localhost:8080/api/v1
